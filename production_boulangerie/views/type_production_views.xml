<?xml version="1.0" encoding="utf-8"?>
    <odoo>

        <!-- ==================== VUE LISTE ==================== -->
        <record id="type_production_view_list" model="ir.ui.view">
            <field name="name">type.production.view.list</field>
            <field name="model">type.production</field>
            <field name="arch" type="xml">
                <list string="Types de production">
                    <field name="code"/>
                    <field name="name"/>
                </list>
            </field>
        </record>

        <!-- ==================== VUE FORMULAIRE ==================== -->
        <record id="type_production_view_form" model="ir.ui.view">
            <field name="name">type.production.view.form</field>
            <field name="model">type.production</field>
            <field name="arch" type="xml">
                <form string="Type de production">
                    <sheet>

                        <div class="oe_title">
                            <h1>
                                <field name="name"
                                    placeholder="Ex : Boulangerie, Pâtisserie..."/>
                            </h1>
                        </div>

                        <group>
                            <field name="code"
                                placeholder="Code généré automatiquement"/>
                        </group>

                        <div class="oe_button_box" name="button_box">
                            <button
                                name="action_generate_code"
                                type="object"
                                string="Régénérer le code"
                                class="oe_stat_button"
                                icon="fa-refresh"
                                confirm="Voulez-vous régénérer le code ?"/>
                        </div>

                    </sheet>
                </form>
            </field>
        </record>

        <!-- ==================== VUE RECHERCHE ==================== -->
    <!-- ==================== VUE RECHERCHE ==================== -->
    <record id="type_production_view_search" model="ir.ui.view">
        <field name="name">type.production.view.search</field>
        <field name="model">type.production</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
            </search>
        </field>
    </record>
        <!-- ==================== ACTION ==================== -->
        <record id="type_production_action" model="ir.actions.act_window">
            <field name="name">Types de production</field>
            <field name="res_model">type.production</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="type_production_view_search"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Créez votre premier type de production.
                </p>
                <p>
                    Les codes peuvent être générés automatiquement à partir du nom.
                </p>
            </field>
        </record>

        <!-- ==================== MENUS ==================== -->

        <menuitem
            id="type_production_menu_root"
            name="Production"
            sequence="40"/>

        <menuitem
            id="type_production_menu_config"
            name="Configuration"
            parent="type_production_menu_root"
            sequence="90"/>

        <menuitem
            id="type_production_menu_action"
            name="Types de production"
            parent="type_production_menu_config"
            action="type_production_action"
            sequence="10"/>

    </odoo>