<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ================= FORM ================= -->
    <record id="view_bakery_product_form" model="ir.ui.view">
        <field name="name">bakery.product.form</field>
        <field name="model">bakery.product</field>
        <field name="arch" type="xml">
            <form string="Produit de boulangerie">

                <sheet>

                    <group>

                        <group string="Informations générales">

                            <field name="product_template_id" invisible="1"/>
                            <field name="name"/>
                            <field name="qty_available" string="Quantite en Stock"/>

 
                              
                            
                           

                        </group>

                       

                    </group>

                    <group string="Tarification">

                        <group>

                            <field name="list_price"  string='Prix de Détail'/>

                            <field name="prix_en_gros"/>

                        </group>

                        <group>

                            <field name="type_tarification"/>

                        </group>

                    </group>

                </sheet>

            </form>
        </field>
    </record>

    <!-- ================= LIST ================= -->

    <record id="view_bakery_product_tree" model="ir.ui.view">
        <field name="name">bakery.product.tree</field>
        <field name="model">bakery.product</field>
        <field name="arch" type="xml">

            <list>

                <field name="name"/>

                <field name="list_price"/>

                <field name="prix_en_gros"/>

                <field name="qty_available"/>

            </list>

        </field>
    </record>

    <!-- ================= ACTION ================= -->

    <record id="action_bakery_products" model="ir.actions.act_window">
        <field name="name">Produits de boulangerie</field>
        <field name="res_model">bakery.product</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>