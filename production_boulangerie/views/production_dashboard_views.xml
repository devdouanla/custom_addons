    <!-- ===================== ACTION ===================== -->
    <record id="action_production_dashboard" model="ir.actions.act_window">
        <field name="name">Tableau de Bord</field>
        <field name="res_model">production.dashboard</field>
        <field name="view_mode">list,graph,pivot</field>
        
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Aucune donnee de production pour le moment</p>
            <p>Le tableau de bord se remplit automatiquement des que des journees de production sont creees.</p>
        </field>
    </record>

    <!-- Menu ajoute dans views/menu.xml (menu_production_dashboard) -->

</odoo>
