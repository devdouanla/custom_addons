<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ===================== VUE LISTE ===================== -->
    <record id="view_production_dashboard_list" model="ir.ui.view">
        <field name="name">production.dashboard.list</field>
        <field name="model">production.dashboard</field>
        <field name="arch" type="xml">
            <list string="Tableau de Bord" create="0" edit="0" delete="0" default_order="date desc">
                <field name="date"/>
                <field name="reference" string="Journee"/>
                <field name="type_production_id" string="Type"/>
                <field name="nb_productions" string="Fiches" sum="Total fiches"/>
                <field name="nb_validees" string="Validees"/>
                <field name="nb_brouillon" string="Brouillon"/>
                <field name="nb_annulees" string="Annulees"/>
                <field name="currency_id" invisible="1"/>
                <field name="production_value" string="Valeur production" widget="monetary" options="{'currency_field': 'currency_id'}" sum="Total valeur"/>
                <field name="consumption_cost" string="Cout matieres" widget="monetary" options="{'currency_field': 'currency_id'}" sum="Total cout"/>
                <field name="profit" string="Profit" widget="monetary" options="{'currency_field': 'currency_id'}" sum="Total profit" decoration-danger="profit &lt; 0" decoration-success="profit &gt; 0"/>
                <field name="profit_rate" string="Taux (%)" decoration-danger="profit_rate &lt; 0"/>
            </list>
        </field>
    </record>

    <!-- ===================== VUE GRAPHIQUE ===================== -->
    <record id="view_production_dashboard_graph" model="ir.ui.view">
        <field name="name">production.dashboard.graph</field>
        <field name="model">production.dashboard</field>
        <field name="arch" type="xml">
            <graph string="Evolution Production / Profit" type="bar">
                <field name="date" interval="day"/>
                <field name="production_value" type="measure" string="Valeur production"/>
                <field name="consumption_cost" type="measure" string="Cout matieres"/>
                <field name="profit" type="measure" string="Profit"/>
            </graph>
        </field>
    </record>

    <!-- ===================== VUE PIVOT ===================== -->
    <record id="view_production_dashboard_pivot" model="ir.ui.view">
        <field name="name">production.dashboard.pivot</field>
        <field name="model">production.dashboard</field>
        <field name="arch" type="xml">
            <pivot string="Analyse Production" display_quantity="true">
                <field name="type_production_id" type="row"/>
                <field name="date" type="col" interval="month"/>
                <field name="production_value" type="measure"/>
                <field name="consumption_cost" type="measure"/>
                <field name="profit" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- ===================== VUE RECHERCHE ===================== 
    <record id="view_production_dashboard_search" model="ir.ui.view">
        <field name="name">production.dashboard.search</field>
        <field name="model">production.dashboard</field>
