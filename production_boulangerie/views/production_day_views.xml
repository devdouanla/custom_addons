<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ===================== FORM VIEW ===================== -->
    <record id="view_production_day_form" model="ir.ui.view">
        <field name="name">production.day.form</field>
        <field name="model">production.day</field>
        <field name="arch" type="xml">
            <form string="Journée de Production">
                <sheet>

                    <!-- Informations générales -->
                    <group string="Informations Générales">
                        <group>
                            <field name="date"/>
                            <field name="reference"/>
                            <!--<field name="state"/>-->
                             <field name="type_production_id" string="type de production"/>
                        </group>
                    </group>

                    <!-- One2many -->

                   <group string="Liste des fiches de production">

                         <field name="production_ids" string="Production" nolabel="1">
                            <!--<list editable="bottom">
                                <field name="name"/>
                            </list>-->
                        </field>
                    </group> 

                </sheet>
            </form>
        </field>
    </record>


    <!-- ===================== LIST VIEW ===================== -->
    <record id="view_production_day_list" model="ir.ui.view">
        <field name="name">production.day.list</field>
        <field name="model">production.day</field>
        <field name="arch" type="xml">
            <list string="Journées de Production">
            <field name="reference" />
                
               <field name="type_production_name" string="type de production"/>
                <field name="date"/>
                <!-- <field name="state"/>-->
            </list>
        </field>
    </record>


    <!-- ===================== ACTION ===================== -->
    <record id="action_production_day" model="ir.actions.act_window">
        <field name="name">Journées de Production</field>
        <field name="res_model">production.day</field>
        <field name="view_mode">list,form</field>

        <field name="view_ids" eval="[
            (5, 0, 0),
            (0, 0, {
                'view_mode': 'list',
                'view_id': ref('view_production_day_list')
            }),
            (0, 0, {
                'view_mode': 'form',
                'view_id': ref('view_production_day_form')
            })
        ]"/>
    </record>

</odoo>